  "bug": {
    "description": "选择优先第 13 周后，推荐结果列表中第 12/15 周方案排在前面，第 13 周方案被 limit=5 截断",
    "rootCause": "全局 score-desc 排序 + limit 截断；preferredWeek 未参与排序优先级；前端无分组展示"
  },
  "fix": {
    "method": "preferredWeek-first bucketed sorting",
    "implementation": {
      "bucketing": "preferredPlans = plans.filter(week === centerWeek), fallbackPlans = plans.filter(week !== centerWeek)",
      "sorting": "preferredPlans.sort(sortByScore) + fallbackPlans.sort(sortByScore)",
      "compositing": "[...preferredPlans, ...fallbackPlans].slice(0, limit)",
      "limitSemantics": "limit 先填 preferred 再填 fallback，不全局 slice"
    },
    "additiveResponseShape": {
      "plan.isPreferredWeek": "boolean (targetWeek === preferredWeek)",
      "result.preferredWeek": "number",
      "result.preferredWeekAvailable": "boolean",
      "result.searched.preferredWeek": "number",
      "result.searched.preferredWeekPlanCount": "number",
      "result.searched.fallbackPlanCount": "number"
    },
    "frontend": {
      "groupedDisplay": "首选周方案 / 备选周方案 分组标签",
      "preferredUnavailableMessage": "第 X 周暂无可用方案，以下为邻近周备选方案",
      "scrollableList": "保留 max-h-64 overflow-y-auto"
    },
