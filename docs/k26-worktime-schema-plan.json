      "isActive": "Boolean @default(true)",
      "isTeachingSlot": "Boolean @default(true)",
      "isLegacyDisplay": "Boolean @default(false)",
      "sortOrder": "Int @default(0)",
      "constraints": [
        "@@unique([workTimeConfigId, slotIndex])",
        "@@index([workTimeConfigId, isActive])"
