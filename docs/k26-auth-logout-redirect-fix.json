  "date": "2026-06-10",
  "bug": {
    "symptom": "Clicking '退出' redirected to http://localhost/login (port 80) and showed ERR_CONNECTION_REFUSED instead of returning to the dev server's /login page on port 3000.",
    "rootCause": "The /logout route hardcoded the redirect base URL to 'http://localhost' (no port). `new URL('/login', 'http://localhost')` produced 'http://localhost/login', which defaults to port 80. The dev server runs on port 3000, so the browser's GET to port 80 failed.",
    "wrongCode": "return NextResponse.redirect(new URL('/login', 'http://localhost'))",
    "fixedCode": "return NextResponse.redirect(new URL('/login', request.url))",
    "filesChanged": [
      "src/app/(auth)/logout/route.ts"
    ]
  },
  "fix": {
    "approach": "Accept the NextRequest in the GET handler and derive the redirect target from request.url so the browser is sent back to /login on the same origin + port.",
    "signatureBefore": "export async function GET() { ... }",
    "signatureAfter": "export async function GET(request: NextRequest) { ... }",
    "redirectBefore": "NextResponse.redirect(new URL('/login', 'http://localhost'))",
    "redirectAfter": "NextResponse.redirect(new URL('/login', request.url))",
    "preservesOrigin": true,
    "preservesPort": true,
