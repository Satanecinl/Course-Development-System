# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Import uploads
uploads/

# Local capacity and class data
/data/class-student-count.csv
/data/room-capacity.csv

# Database
prisma/dev.db
prisma/dev.db.backup-*
prisma/dev.db-journal

# Local database backups
/prisma/backups/

# Screenshots (UI verification)
scripts/f2-verify-screenshots/

# K31-A export sample (regenerated by verify script)
scripts/k31-a-sample/

# K32-A export sample (regenerated by verify script)
scripts/k32-a-sample/

# Logs
*.log

# Python cache
__pycache__/
*.pyc

# CodeGraph
.codegraph/

# Local tool configuration
/.claude/

# K35-A: temp directory for local-only artifacts, manual trial outputs,
# unsanitized drafts, DB backup pointers, etc. The temp/README.md itself
# is the only tracked file inside temp/ — everything else is ignored.
/temp/**
!/temp/README.md
!/temp/.gitkeep
